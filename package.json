{
  "name": "pet-ai-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @pet-ai/api --filter @pet-ai/admin --parallel dev",
    "build": "pnpm --filter @pet-ai/shared --filter @pet-ai/api --filter @pet-ai/admin build && pnpm --filter @pet-ai/miniapp build:mp-weixin",
    "typecheck": "pnpm --filter @pet-ai/shared --filter @pet-ai/api --filter @pet-ai/admin typecheck && pnpm --filter @pet-ai/miniapp exec tsc --noEmit",
    "lint": "pnpm typecheck",
    "dev:miniapp": "pnpm --filter @pet-ai/miniapp dev:mp-weixin",
    "build:miniapp": "pnpm --filter @pet-ai/miniapp build:mp-weixin"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
